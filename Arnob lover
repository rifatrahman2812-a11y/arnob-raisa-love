<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Arnob ❤️ Raisa</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI;
}

body{
height:100vh;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
text-align:center;
color:white;
background:linear-gradient(-45deg,#ff4e50,#ff6a88,#ff99ac,#ff2d55);
background-size:400% 400%;
animation:bg 10s ease infinite;
overflow:hidden;
}

@keyframes bg{
0%{background-position:0% 50%}
50%{background-position:100% 50%}
100%{background-position:0% 50%}
}

h1{
font-size:65px;
text-shadow:0 0 20px white,0 0 40px pink;
animation:glow 2s infinite alternate;
}

@keyframes glow{
from{transform:scale(1)}
to{transform:scale(1.05)}
}

.heart{
font-size:70px;
animation:beat 1s infinite;
}

@keyframes beat{
0%{transform:scale(1)}
50%{transform:scale(1.3)}
100%{transform:scale(1)}
}

.message{
margin-top:25px;
font-size:25px;
min-height:40px;
}

button{
margin-top:30px;
padding:15px 35px;
font-size:18px;
border:none;
border-radius:30px;
background:#ff2d55;
color:white;
cursor:pointer;
transition:.4s;
}

button:hover{
transform:scale(1.1);
background:#ff003c;
}

.kiss{
position:absolute;
font-size:30px;
animation:kissmove 6s linear infinite;
}

@keyframes kissmove{
0%{transform:translateY(100vh)}
100%{transform:translateY(-10vh)}
}

.star{
position:absolute;
color:white;
font-size:14px;
animation:stars 8s linear infinite;
}

@keyframes stars{
0%{transform:translateY(-10vh)}
100%{transform:translateY(110vh)}
}

</style>
</head>

<body>

<h1>Arnob ❤️ Lover Raisa</h1>

<div class="heart">💞</div>

<div class="message" id="text"></div>

<button onclick="showLove()">Click For Love</button>

<script>

const message="Arnob Loves Raisa Forever 💖 You Are My Heart 💋";

let i=0;

function showLove(){
let typing=setInterval(()=>{
if(i<message.length){
document.getElementById("text").innerHTML+=message.charAt(i);
i++;
}else{
clearInterval(typing);
}
},80);
}

function createKiss(){
const kiss=document.createElement("div");
kiss.className="kiss";
kiss.innerHTML="💋";

kiss.style.left=Math.random()*100+"vw";

document.body.appendChild(kiss);

setTimeout(()=>kiss.remove(),6000);
}

setInterval(createKiss,700);

function createStar(){
const star=document.createElement("div");
star.className="star";
star.innerHTML="✨";

star.style.left=Math.random()*100+"vw";

document.body.appendChild(star);

setTimeout(()=>star.remove(),8000);
}

setInterval(createStar,400);

</script>

</body>
</html>
